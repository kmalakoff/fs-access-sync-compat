    "@types/node": "^22.10.1",
    "depcheck": "^1.4.7",
    "ts-dev-stack": "^1.0.1"
  },
  "engines": {
    "node": ">=0.8"
  },
  "tsds": {
    "source": "src/index.mjs",
    "targets": [
      "cjs"
    ]
  }
